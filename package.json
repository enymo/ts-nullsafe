{
  "name": "@enymo/ts-nullsafe",
  "version": "1.1.2",
  "description": "Minimal library for implementing null-safety with typescript.",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "tsdown": {
    "entry": [
      "src/js/index.ts"
    ],
    "format": [
      "esm",
      "cjs"
    ],
    "dts": true
  },
  "scripts": {
    "build": "tsdown"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enymo/ts-nullsafe.git"
  },
  "author": "enymo GmbH",
  "license": "MIT",
  "devDependencies": {
    "postcss": "^8.4.17",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3"
  }
}
